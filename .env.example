# ─────────────────────────────────────────────────────────────────────────────
# BetterAgent environment variables
#
# Copy to `.env.local` and fill in real values: `cp .env.example .env.local`
# Variables marked (required) must be set for the app to function.
# Variables marked (required in prod) must be set in production deployments.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────────────────────

# (required) Postgres connection string (Neon). Use the pooled connection URL.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# (required) Secret used by better-auth to sign sessions/tokens.
# Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-a-long-random-string"

# (required) Canonical base URL of this app, used by better-auth.
# Local: http://localhost:3000 — Prod: https://betteragent.dev
BETTER_AUTH_URL="http://localhost:3000"

# Node environment. Set to "production" in production deploys (Vercel sets this
# automatically). Controls fail-closed rate limiting and the SSRF guard.
NODE_ENV="development"

# ── Public (exposed to the browser — must be safe to publish) ────────────────

# (required) Public origin of the app, used in emails and links.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Base URL the browser SDK / dashboard uses to reach the chat API.
# Local: http://localhost:3000 — Prod: https://www.betteragent.dev
NEXT_PUBLIC_BETTERAGENT_API_URL="http://localhost:3000"

# Publishable client key for the dashboard's own embedded agent (optional).
NEXT_PUBLIC_BETTERAGENT_CLIENT_KEY="ba_client_xxxxxxxxxxxxxxxxxxxxxxxx"

# Publishable client key used by the public /demo page (optional).
NEXT_PUBLIC_BETTERAGENT_DEMO_CLIENT_KEY="ba_client_xxxxxxxxxxxxxxxxxxxxxxxx"

# ── Server-side API base ─────────────────────────────────────────────────────

# Server-side base URL for the BetterAgent API (used by server code / CLI).
BETTERAGENT_API_URL="http://localhost:3000"

# ── AI + email ───────────────────────────────────────────────────────────────

# (required) Anthropic API key — powers chat and AI description generation.
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx"

# (required for BYOK) Secret used to encrypt customers' Anthropic keys at rest
# (AES-256-GCM). Must be base64 of 32 bytes — generate with `openssl rand -base64 32`.
KEY_ENCRYPTION_SECRET=""

# (required for email) Resend API key. Without it, auth codes/emails are logged
# to the console instead of being sent.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"

# From address for outbound email.
FROM_EMAIL="BetterAgent <noreply@betteragent.dev>"

# ── Rate limiting (Upstash Redis) ────────────────────────────────────────────
# (required in prod) Without these, rate limiting fails OPEN in dev/preview and
# fails CLOSED (rejects all requests) in production. Set both in production.
UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxx"

# ── Cron ─────────────────────────────────────────────────────────────────────

# (required for cron) Shared secret guarding /api/cron/* routes. Vercel cron
# jobs must send it as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET="replace-with-a-long-random-string"

# ── OAuth sign-in (optional) ─────────────────────────────────────────────────
# Configure a provider only if you want that social login enabled. Both the ID
# and secret must be set for a provider to activate.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ── Stripe (per-project billing) ─────────────────────────────────────────────
# Secret key + webhook signing secret (from `stripe listen` locally, or the
# Dashboard webhook endpoint in production).
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Recurring price IDs (create the products/prices in Stripe first).
STRIPE_PRICE_STARTER=""          # Starter — $0.99/mo flat
STRIPE_PRICE_PLUS=""             # Plus — $14.99/mo flat
STRIPE_PRICE_PLUS_OVERAGE=""     # Plus — metered usage price ($0.01/credit = $10/1k)

# Billing Meter event name the overage price aggregates (must match the meter).
STRIPE_OVERAGE_METER_EVENT="betteragent_overage"
