{
  "name": "betteragent",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:pull": "bunx dotenv -e .env.local -- bunx prisma db pull",
    "db:push": "bunx dotenv -e .env.local -- bunx prisma db push",
    "db:generate": "bunx dotenv -e .env.local -- bunx prisma generate",
    "cli:build": "cd packages/cli && bun run build",
    "cli:types": "cd packages/cli && bunx tsc --noEmit",
    "next:build": "cd packages/next && bun run build",
    "next:types": "cd packages/next && bunx tsc --noEmit",
    "react:build": "cd packages/react && bun run build",
    "react:types": "cd packages/react && bunx tsc --noEmit",
    "packages:build": "bun run next:build && bun run react:build && bun run cli:build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.77",
    "@ai-sdk/react": "^3.0.179",
    "@betteragent/next": "workspace:*",
    "@betteragent/react": "workspace:*",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "next-themes": "^0.4.6",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-query": "^5.100.9",
    "ai": "^6.0.177",
    "better-auth": "^1.6.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "input-otp": "^1.4.2",
    "next": "16.2.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.75.0",
    "resend": "^6.12.3",
    "shadcn": "^4.7.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "prisma": "^7.8.0",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
